{"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SequentialExecutor\/documentation\/SequentialExecutor","doc:\/\/SequentialExecutor\/documentation\/SequentialExecutor\/SequentialExecutor"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SequentialExecutor\/documentation\/SequentialExecutor\/SequentialExecutor\/runNow()"},"kind":"symbol","metadata":{"modules":[{"name":"SequentialExecutor"}],"externalID":"s:18SequentialExecutorAAC6runNowyyYaF","role":"symbol","extendedModule":"SequentialExecutor","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"runNow","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"}],"title":"runNow()","roleHeading":"Instance Method","symbolKind":"method"},"abstract":[{"type":"text","text":"Requests a new immediate execution."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/sequentialexecutor\/sequentialexecutor\/runnow()"]}],"sections":[],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"runNow"},{"kind":"text","text":"() "},{"kind":"keyword","text":"async"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Immediate execution has priority over the scheduled loop. If a loop is active,"},{"type":"text","text":" "},{"type":"text","text":"it is stopped first. If another execution is already running, it is cancelled"},{"type":"text","text":" "},{"type":"text","text":"and replaced by the new one. If multiple callers race to invoke "},{"type":"codeVoice","code":"runNow()"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"only the latest pending request is guaranteed to proceed after cancellation"},{"type":"text","text":" "},{"type":"text","text":"coordination completes. Cancellation remains cooperative: this method requests"},{"type":"text","text":" "},{"type":"text","text":"cancellation of the in-flight execution and waits for it to return; it does not"},{"type":"text","text":" "},{"type":"text","text":"forcibly terminate non-cooperative work."}]}],"kind":"content"}],"references":{"doc://SequentialExecutor/documentation/SequentialExecutor/SequentialExecutor/runNow()":{"url":"\/documentation\/sequentialexecutor\/sequentialexecutor\/runnow()","abstract":[{"type":"text","text":"Requests a new immediate execution."}],"kind":"symbol","identifier":"doc:\/\/SequentialExecutor\/documentation\/SequentialExecutor\/SequentialExecutor\/runNow()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"runNow","kind":"identifier"},{"text":"() ","kind":"text"},{"text":"async","kind":"keyword"}],"title":"runNow()","type":"topic"},"doc://SequentialExecutor/documentation/SequentialExecutor":{"identifier":"doc:\/\/SequentialExecutor\/documentation\/SequentialExecutor","url":"\/documentation\/sequentialexecutor","kind":"symbol","abstract":[{"text":"一个按顺序执行异步任务的执行器。","type":"text"}],"role":"collection","title":"SequentialExecutor","type":"topic"},"doc://SequentialExecutor/documentation/SequentialExecutor/SequentialExecutor":{"url":"\/documentation\/sequentialexecutor\/sequentialexecutor","navigatorTitle":[{"text":"SequentialExecutor","kind":"identifier"}],"role":"symbol","title":"SequentialExecutor","kind":"symbol","identifier":"doc:\/\/SequentialExecutor\/documentation\/SequentialExecutor\/SequentialExecutor","abstract":[{"type":"text","text":"Runs one execution at a time."}],"type":"topic","fragments":[{"kind":"keyword","text":"actor"},{"text":" ","kind":"text"},{"text":"SequentialExecutor","kind":"identifier"}]}}}